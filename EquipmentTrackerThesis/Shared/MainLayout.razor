@using EquipmentTrackerThesis.Data;
@using EquipmentTrackerThesis.Database;
@using MudBlazor
@inherits LayoutComponentBase

@inject EquipmentTrackerThesis.ILocalStorage LocalStorage
@inject IJSRuntime JSRuntime
@inject DatabaseHandler _dbHandler
@inject SignInCheck signInCheck
@inject NavigationManager navigationmanager

<CascadingValue Value="this">
    <MudThemeProvider Theme="_theme" IsDarkMode="true" />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <PageTitle>Equipment Tracker</PageTitle>

    <MudLayout>
        <MudAppBar Elevation="1" Style="background-color: #1a1f2e; border-bottom: 1px solid #2d3748;">
        <MudIcon Icon="@Icons.Material.Filled.Business" Style="color: #4a6fa5; margin-right: 8px; font-size: 28px;" />            <MudText Typo="Typo.h6" Style="color: #e2e8f0; font-weight: 500;">Vállalati Nyilvántartás</MudText>
            <MudSpacer />
            @if (loggedIn)
            {
                <MudTooltip Text="Személyes adatok">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Default" Href="account" Style="color: #a0aec0;" />
                </MudTooltip>
                <MudTooltip Text="Kilépés">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Default" OnClick="Logout" Style="color: #a0aec0;" />
                </MudTooltip>
            }
            else
            {
                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Login"
                           Style="background-color: #4a6fa5; color: white;"
                           OnClick="OpenLogin">Belépés</MudButton>
            }
        </MudAppBar>

        <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2"
                   Style="background-color: #1a1f2e; border-right: 1px solid #2d3748;">
            <MudNavMenu Style="padding-top: 8px;">
                <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home"
                           Style="color: #a0aec0;">Főoldal</MudNavLink>
                <MudNavLink Href="account" Icon="@Icons.Material.Filled.Person"
                           Style="color: #a0aec0;">Személyes adatok</MudNavLink>
                <MudNavLink Href="accesses" Icon="@Icons.Material.Filled.Badge"
                           Style="color: #a0aec0;">Jogosultságok</MudNavLink>
                <MudNavLink Href="devices" Icon="@Icons.Material.Filled.Devices"
                           Style="color: #a0aec0;">Céges eszközök</MudNavLink>
                @if (IsLoggedIn() && signInCheck.GetRole() == "Admin")
                {
                    <MudDivider Style="margin: 8px 0; border-color: #2d3748;" />
                    <MudText Typo="Typo.caption" Style="color: #4a5568; padding: 8px 16px; display: block;">Admin</MudText>
                    <MudNavLink Href="addEmployee" Icon="@Icons.Material.Filled.PersonAdd"
                               Style="color: #a0aec0;">Beléptetés</MudNavLink>
                    <MudNavLink Href="removeEmployee" Icon="@Icons.Material.Filled.PersonRemove"
                               Style="color: #a0aec0;">Kiléptetés</MudNavLink>
                }
            </MudNavMenu>
        </MudDrawer>

        <MudMainContent Style="background-color: #0f1117; min-height: 100vh;">
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Style="padding: 24px;">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
</CascadingValue>

<MudOverlay Visible="display" DarkBackground="true" ZIndex="1200" />

<MudDialog @bind-IsVisible="display" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Login" Style="margin-right: 8px;" />
            Bejelentkezés
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="user" Label="E-mail" Placeholder="nev@vallalat.hu"
                     InputType="InputType.Email" Variant="Variant.Outlined"
                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                     Style="margin-bottom: 16px;" />
        <MudTextField @bind-Value="password" Label="Jelszó"
                     InputType="InputType.Password" Variant="Variant.Outlined"
                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Style="margin-top: 16px;">@errorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text" Style="color: #a0aec0;">Mégse</MudButton>
        <MudButton OnClick="Login" Variant="Variant.Filled"
                  Style="background-color: #4a6fa5; color: white;">Belépés</MudButton>
    </DialogActions>
</MudDialog>

@code {

    private MudTheme _theme = new MudTheme();
    private DialogOptions _dialogOptions = new DialogOptions { 
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };
    private bool show, display, loggedIn;
    private string? user, password;
    private string? errorMessage;

    public string? GetUserName()
    {
        return loggedIn ? user : null;
    }
    public bool IsLoggedIn()
    {
    return loggedIn;
    }  

    /// <summary>
    /// Opens the log in menu.
    /// </summary>
    /// <returns></returns>
    public async Task OpenLogin()
    {
    user = await LocalStorage.GetStringAsync("user", JSRuntime);
    display = true;
    StateHasChanged();
    }

    /// <summary>
    /// Logs out the user and navigates to the Account page.
    /// </summary>
    /// <returns></returns>
    public async Task Logout()
    {
        user = null;
        loggedIn = false;
        await LocalStorage.RemoveAsync("user", JSRuntime);
        signInCheck.CurrentEmployee = new EmployeeModel
            {
                Username = ""
            };
        navigationmanager.NavigateTo("/");
    }

    /// <summary>
    /// Closes the dialog window.
    /// </summary>
    /// <returns></returns>
    private async Task Close()
    {
    display = false;
    errorMessage = null;
    await Task.Delay(200);
    StateHasChanged();
    }

    /// <summary>
    /// If the user field filled in, this method starts the SignIn method.
    /// </summary>
    private void Login()
    {
        if (!string.IsNullOrEmpty(user))
        {
            SignIn();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!loggedIn)
            {
                await LocalStorage.RemoveAsync("user", JSRuntime);
            }
            StateHasChanged();
        }
    }

    /// <summary>
    /// If the username and password fields are not empty, the method tries to log in the user.
    /// </summary>
    private async void SignIn()
    {
        if (!string.IsNullOrEmpty(user) && !string.IsNullOrEmpty(password))
        {
        bool isAuthenticated = signInCheck.SignInAttempt(user, password);
            if (isAuthenticated)
            {
                var logins = _dbHandler.GetAllLogins();
                var currentLogin = logins.First(x => x.Username == user);
                currentLogin.LastLogin = DateTime.Now;
                _dbHandler.UpdateLogin(currentLogin);

                loggedIn = true;
                await LocalStorage.SaveStringAsync("user", user, JSRuntime);
                navigationmanager.NavigateTo("/account");
                await Close();
            }
            else
            {
                errorMessage = "A felhasználónév és/vagy a jelszó helytelen!";
                //user = null;
                password = null;
                StateHasChanged();
            }
        }
        else
        {
            errorMessage = "A felhasználónév és/vagy a jelszó helytelen!";
            StateHasChanged();
        }
    }
}