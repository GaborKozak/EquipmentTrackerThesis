@using EquipmentTrackerThesis.Data;
@using EquipmentTrackerThesis.Database;
@using EquipmentTrackerThesis.Database.Models;
@using EquipmentTrackerThesis.Pages.Components;
@using MudBlazor
@inject DatabaseHandler _databaseHandler;

@if (ShowBackdrop)
{
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:1200;" @onclick="Close"></div>
}

@if (ModalDisplay == "block;")
{
    <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1300;width:500px;max-width:95vw;max-height:90vh;overflow-y:auto;">
        <MudPaper Elevation="8" Style="background-color: #1e2535; border: 1px solid #2d3748; border-radius: 12px; padding: 0;">
            <div style="background-color: #2a3550; padding: 16px 24px; border-radius: 12px 12px 0 0; display:flex; align-items:center; justify-content:space-between;">
                <MudText Typo="Typo.h6" Style="color: #e2e8f0;">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="margin-right:8px; vertical-align:middle;" />
                    Új eszköz hozzáadása
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" Style="color: #a0aec0;" Size="Size.Small" />
            </div>
            <div style="padding: 24px;">
                <MudTextField Label="Név" @bind-Value="Name"
                             Variant="Variant.Outlined" Style="margin-bottom:16px;" />
                <MudTextField Label="Gyártási szám" @bind-Value="SerialNumber"
                             Variant="Variant.Outlined" Style="margin-bottom:16px;" />
                <MudSelect T="string" Label="Típus" @bind-Value="selectedType"
                          Variant="Variant.Outlined" Style="margin-bottom:16px;">
                    @foreach (var type in types)
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
                <div style="margin-bottom:16px;">
                    <MudText Style="color: #a0aec0; font-size:12px; margin-bottom:4px;">Vásárlás dátuma:</MudText>
                    <DatePicker Name="@("Dátum választása")" @bind-Value="@selectedPurchaseDate"></DatePicker>
                </div>
                <MudSelect T="int" Label="Tulajdonos" @bind-Value="selectedOwnerId"
                          Variant="Variant.Outlined" Style="margin-bottom:16px;">
                    @foreach (var emp in employees)
                    {
                        if (emp.IsActive == true)
                        {
                            <MudSelectItem Value="@emp.Id">@emp.SurName @emp.FirstName</MudSelectItem>
                        }
                    }
                </MudSelect>
                <div style="margin-bottom:16px;">
                    <MudText Style="color: #a0aec0; font-size:12px; margin-bottom:4px;">Átvétel dátuma:</MudText>
                    <DatePicker Name="@("Dátum választása")" @bind-Value="@selectedReceptionDate"></DatePicker>
                </div>
            </div>
            <div style="padding: 16px 24px; border-top: 1px solid #2d3748; display:flex; justify-content:flex-end; gap:8px;">
                <MudButton Variant="Variant.Text" OnClick="Close" Style="color: #a0aec0;">Mégse</MudButton>
                <MudButton Variant="Variant.Filled" OnClick="Add"
                          Style="background-color: #4a6fa5; color: white;">Hozzáadás</MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter]
    public string? Title { get; set; }
    [Parameter]
    public string? Body { get; set; }
    [Parameter]
    public int Assignment { get; set; }
    [Parameter]
    public string? SerialNumber { get; set; }
    [Parameter]
    public string? Name { get; set; }
    [Parameter]
    public string? Type_ { get; set; }
    [Parameter]
    public DateOnly PurchaseDate { get; set; }
    [Parameter]
    public int Owner { get; set; }
    [Parameter]
    public DateOnly ReceptionDate { get; set; }
    [Parameter]
    public DateOnly ReturnDate { get; set; }
    [Parameter]
    public Devices? Device { get; set; }
    private ModalWindowType _type;
    [Parameter]
    public ModalWindowType Type
    {
        get
        {
            return _type;
        }
        set
        {
            _type = value;
        }
    }

    List<string> types = new List<string>();
    List<Employee> employees = new List<Employee>();
    List<JobTitle> jobTitle = new List<JobTitle>();

    public Guid Guid = Guid.NewGuid();
    public string ModalDisplay = "none;";
    public string ModalClass = "";
    public string selectedType = "";
    public bool ShowBackdrop = false;
    public int selectedOwnerId;
    DateTime selectedPurchaseDate;
    DateTime selectedReceptionDate;

    /// <summary>
    /// This method opens the dialog window.
    /// </summary>
    public void Open()
    {
        ModalDisplay = "block;";
        ModalClass = "Show";
        ShowBackdrop = true;
        StateHasChanged();
        types = new List<string> { "Mobil", "Laptop", "Tablet", "Jármű" };
        Type = ModalWindowType.Adding;

        employees = _databaseHandler.GetAllEmployees();
        jobTitle = _databaseHandler.GetAllJobTitles();
    }

    /// <summary>
    /// This method closes the dilog window.
    /// </summary>
    public void Close()
    {
        ModalDisplay = "none";
        ModalClass = "";
        ShowBackdrop = false;
        StateHasChanged();
    }

    /// <summary>
    /// This method creates a new Device and adds to the database. 
    /// </summary>
    public void Add()
    {
        Device = new Devices();
        if (SerialNumber != null)
        {
            Device.SerialNumber = SerialNumber;
        }
        if (Name != null)
        {
            Device.Name = Name;
        }
        Device.Type = selectedType;
        Device.PurchaseDate = selectedPurchaseDate.Date;
        Device.Owner = selectedOwnerId;
        Device.ReceptionDate = selectedReceptionDate.Date;
        Device.ReturnDate = selectedReceptionDate.Date;
        Device.Archived = false;

        _databaseHandler.AddNewDevice(Device);
        Close();
    }

    /// <summary>
    /// This method helps to get the dialog window's style.
    /// </summary>
    /// <returns></returns>
    private string ModalTypeToClass()
    {
        switch (Type)
        {
            case ModalWindowType.Modify:
                return "msg-loop-circular";
            case ModalWindowType.Adding:
                return "msg-plus";
            case ModalWindowType.Warning:
                return "msg-warning";
            case ModalWindowType.Error:
                return "msg-error";
            default:
                return "msg-info";
        }
    }

    /// <summary>
    /// This method helps to define the icon of the dialog window.
    /// </summary>
    /// <returns></returns>
    private string IconFromModalType()
    {
        //Icons: https://icon-sets.iconify.design/oi/
        switch (Type)
        {
            case ModalWindowType.Modify:
                return "loop-circular";
            case ModalWindowType.Adding:
                return "plus";
            case ModalWindowType.Warning:
                return "warning";
            case ModalWindowType.Error:
                return "circle-x";
            default:
                return "info";
        }
    }
}